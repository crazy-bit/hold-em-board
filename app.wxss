/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 主按钮 */
.btn-primary {
  background: #e94560;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  background: #fff;
  color: #e94560;
  border: 2rpx solid #e94560;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
  width: 100%;
}

.btn-secondary::after {
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-danger::after {
  border: none;
}

/* 禁用状态 */
.btn-disabled {
  opacity: 0.5;
}

/* 输入框 */
.input-field {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

/* 标题 */
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-active {
  background: #e8f5e9;
  color: #4caf50;
}

.tag-finished {
  background: #e3f2fd;
  color: #2196f3;
}

.tag-cancelled {
  background: #fafafa;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #bbb;
}

.empty-state image {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.empty-state text {
  display: block;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 24rpx 0;
}

/* flex 工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 26rpx;
}
