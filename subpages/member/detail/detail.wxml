<!-- pages/member/detail/detail.wxml -->
<view class="container">
  <!-- 成员信息头部 -->
  <view class="member-header card">
    <view class="flex-between">
      <view>
        <text class="member-name">{{memberInfo.nickName}}</text>
        <text class="meta-text">参与 {{scores.length}} 期对局</text>
      </view>
      <view class="total-wrap">
        <text class="total-label">总积分</text>
        <text class="total-points {{totalPoints >= 0 ? 'positive' : 'negative'}}">
          {{totalPoints >= 0 ? '+' : ''}}{{totalPoints}}
        </text>
      </view>
    </view>
  </view>

  <!-- 历史对局积分 -->
  <text class="section-title">历史对局记录</text>

  <t-empty description="暂无对局记录" wx:if="{{scores.length === 0}}" />

  <view
    class="score-card card"
    wx:for="{{scores}}"
    wx:key="_id"
  >
    <view class="flex-between">
      <view>
        <text class="match-title">{{item.matchTitle || '对局'}}</text>
        <text class="match-date">{{item.matchDateStr}}</text>
      </view>
      <view style="text-align:right;">
        <view wx:if="{{item.roundPoints !== null && item.roundPoints !== undefined}}">
          <text class="score-points {{item.roundPoints >= 0 ? 'positive' : 'negative'}}">{{item.roundPoints >= 0 ? '+' : ''}}{{item.roundPoints}}</text>
          <text class="bonus-tag" wx:if="{{item.bonus > 0}}">(bonus:{{item.bonus}})</text>
        </view>
        <text class="score-points unfilled" wx:else>未结算</text>
        <view class="chips-detail">
          <text>{{item.initialChips}} → {{item.finalChips !== null ? item.finalChips : '?'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
