<!-- pages/rules/edit/edit.wxml -->
<view class="container">
  <text class="page-title">积分规则配置</text>

  <!-- 额外加成是否计入总积分 -->
  <view class="card">
    <view class="flex-between">
      <view>
        <text class="rule-label">额外加成计入总积分</text>
        <text class="rule-desc">开启后，额外加成将加入本期积分计算</text>
      </view>
      <switch
        checked="{{bonusCountsToTotal}}"
        bindchange="onBonusToggle"
        color="#e94560"
      />
    </view>
  </view>

  <!-- 筹码规则列表 -->
  <view class="card">
    <view class="flex-between" style="margin-bottom:24rpx;">
      <text class="section-title" style="margin-bottom:0;">初始筹码规则</text>
      <view class="add-btn" bindtap="addRule">+ 添加名次</view>
    </view>

    <!-- 规则说明 -->
    <text class="rule-tip">名次=0 为默认规则（未上榜成员适用）</text>

    <!-- 规则行 -->
    <view class="rule-row" wx:for="{{chipRules}}" wx:key="index">
      <view class="flex-between rule-header">
        <text class="rank-label">
          {{item.rank === 0 ? '默认（未上榜）' : '第 ' + item.rank + ' 名'}}
        </text>
        <view class="del-btn" bindtap="deleteRule" data-index="{{index}}" wx:if="{{item.rank !== 0}}">
          删除
        </view>
      </view>
      <view class="flex-row rule-inputs">
        <view class="input-group">
          <text class="input-label">初始筹码</text>
          <t-input
            type="number"
            value="{{item.initialChips}}"
            bind:change="onChipsInput"
            data-index="{{index}}"
            data-field="initialChips"
            style="padding: 12rpx 0;"
          />
        </view>
        <view class="input-group">
          <text class="input-label">额外加成</text>
          <t-input
            type="number"
            value="{{item.bonus}}"
            bind:change="onChipsInput"
            data-index="{{index}}"
            data-field="bonus"
            style="padding: 12rpx 0;"
          />
        </view>
      </view>
    </view>
  </view>

  <t-button
    theme="danger"
    block
    shape="round"
    style="margin-top:48rpx;"
    bindtap="saveRules"
    disabled="{{saving}}"
    loading="{{saving}}"
  >
    保存规则
  </t-button>

  <text class="save-tip">规则变更将对所有赛程生效</text>
</view>

<t-toast id="t-toast" />
