/* pages/match/detail/detail.wxss */
.match-header {
  margin-bottom: 24rpx;
}

.match-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.match-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.admin-actions {
  margin-bottom: 24rpx;
}

.scores-section {
  margin-top: 8rpx;
}

/* 表头 */
.score-header {
  padding: 16rpx 32rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.col-name {
  flex: 2;
  font-size: 24rpx;
  color: #999;
}

.col-chips {
  flex: 1.5;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.col-points {
  flex: 1.5;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

/* 分数行 */
.score-row {
  padding: 24rpx 32rpx;
  margin-bottom: 12rpx;
  cursor: pointer;
}

.col-name-wrap {
  flex: 2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 48rpx;
}

.self-tag {
  background: #e94560;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}

.col-chips-val {
  flex: 1.5;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  line-height: 48rpx;
}

.bonus {
  color: #ff9800;
}

.unfilled {
  color: #bbb;
  font-size: 24rpx;
}

.col-points-val {
  flex: 1.5;
  font-size: 30rpx;
  font-weight: 700;
  text-align: right;
  line-height: 48rpx;
}

.positive {
  color: #4caf50;
}

.negative {
  color: #f44336;
}

/* 未填写提示 */
.unfilled-tip {
  text-align: center;
  padding: 24rpx;
  color: #ff9800;
  font-size: 26rpx;
  background: #fff8e1;
  border-radius: 12rpx;
  margin-top: 16rpx;
}




.unfilled-warning {
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.unfilled-warning text {
  display: block;
  font-size: 26rpx;
  color: #f57c00;
}

.unfilled-name {
  font-weight: 600;
  margin-top: 8rpx;
}
