/* pages/group/detail/detail.wxss */
.group-header {
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-code {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.action-btns {
  flex-shrink: 0;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
  font-size: 26rpx;
  color: #555;
  white-space: nowrap;
}

.share-btn-wrap {
  position: relative;
  overflow: hidden;
}

.share-btn-hidden {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  margin: 0;
  padding: 0;
  border: none;
}

.share-btn-hidden::after {
  border: none;
}

.action-btn-primary {
  background: #e94560;
  color: #fff;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}




/* 赛程卡片 */
.match-card {
  cursor: pointer;
}

.match-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.match-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  line-height: 48rpx;
}

/* 排行榜 */
.rank-card {
  cursor: pointer;
}

.rank-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.rank-points-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  height: 48rpx;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #999;
}

.rank-gold {
  background: #FFD700;
  color: #fff;
}

.rank-silver {
  background: #C0C0C0;
  color: #fff;
}

.rank-bronze {
  background: #CD7F32;
  color: #fff;
}

.rank-top {
  color: #e94560;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 4rpx;
}

.rank-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.rank-avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.total-points {
  font-size: 36rpx;
  font-weight: 700;
  text-align: right;
  min-width: 80rpx;
  line-height: 1;
}

.points-positive {
  color: #4caf50;
}

.points-negative {
  color: #f44336;
}
