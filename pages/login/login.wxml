<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="logo-wrap">
    <view class="logo-icon">🃏</view>
    <text class="app-name">德州记分板</text>
    <text class="app-desc">轻松记录每一局的胜负</text>
  </view>

  <view class="login-card">
    <text class="login-tip">设置头像和昵称开始使用</text>

    <!-- 头像选择 -->
    <view class="avatar-row">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{avatarUrl || '/images/default-avatar.png'}}" wx:if="{{avatarUrl}}" />
        <view class="avatar-placeholder" wx:else>
          <text class="avatar-plus">+</text>
        </view>
      </button>
      <text class="avatar-hint">点击选择头像</text>
    </view>

    <!-- 昵称输入 -->
    <view class="nickname-row">
      <input
        type="nickname"
        class="nickname-input"
        placeholder="请输入昵称"
        value="{{nickName}}"
        bindinput="onNickNameInput"
        bindblur="onNickNameBlur"
      />
    </view>

    <button
      class="btn-login"
      bindtap="onLoginTap"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '开始使用'}}
    </button>
  </view>
</view>
