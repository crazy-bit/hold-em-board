{
  "name": "hold-em-board",
  "version": "1.0.0",
  "description": "德州扑克记分板小程序",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:e2e": "jest --config jest.config.e2e.js --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "node patch-automator.js",
    "auto:start": "node start-auto.js"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "miniprogram-automator": "^0.12.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/cloudfunctions/"
    ],
    "collectCoverageFrom": [
      "utils/**/*.js",
      "cloudfunctions/**/index.js",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 60000
  },
  "dependencies": {
    "@vant/weapp": "^1.11.7"
  }
}
