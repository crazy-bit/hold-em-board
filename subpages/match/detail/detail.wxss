/* pages/match/detail/detail.wxss */
.match-header {
  margin-bottom: 24rpx;
}

.match-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #eaeaea;
  display: block;
  margin-bottom: 8rpx;
}

.match-date {
  font-size: 24rpx;
  color: #a0a0b0;
  display: block;
}

.admin-actions {
  margin-bottom: 24rpx;
}

.scores-section {
  margin-top: 8rpx;
}

/* 表格网格 */
.score-grid {
  display: grid;
  grid-template-columns: 2fr 1.2fr 1.2fr 1.2fr 1.2fr;
  align-items: center;
  gap: 0 8rpx;
}

/* 表头 */
.score-header {
  padding: 16rpx 32rpx;
  background: #16213e;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.col-name {
  font-size: 24rpx;
  color: #a0a0b0;
}

.col-header {
  font-size: 24rpx;
  color: #a0a0b0;
  text-align: center;
}

.col-last {
  text-align: right;
}

/* 分数行 */
.score-row {
  padding: 24rpx 32rpx;
  margin-bottom: 12rpx;
  cursor: pointer;
}

.col-name-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #eaeaea;
}

.self-tag {
  background: #e94560;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.col-val {
  font-size: 28rpx;
  color: #eaeaea;
  text-align: center;
}

.bonus {
  color: #ff9800;
}

.unfilled {
  color: #666680;
  font-size: 24rpx;
}

.positive {
  color: #4caf50;
  font-weight: 700;
}

.negative {
  color: #f44336;
  font-weight: 700;
}

/* 未填写提示 */
.unfilled-tip {
  text-align: center;
  padding: 24rpx;
  color: #ff9800;
  font-size: 26rpx;
  background: rgba(255, 152, 0, 0.1);
  border-radius: 12rpx;
  margin-top: 16rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

.unfilled-warning {
  background: rgba(255, 152, 0, 0.1);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

.unfilled-warning text {
  display: block;
  font-size: 26rpx;
  color: #ff9800;
}

.unfilled-name {
  font-weight: 600;
  margin-top: 8rpx;
}
