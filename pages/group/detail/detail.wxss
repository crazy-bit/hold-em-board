/* pages/group/detail/detail.wxss */
.group-header {
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-code {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.action-btns {
  flex-shrink: 0;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #f0f0f0;
  font-size: 26rpx;
  color: #555;
  white-space: nowrap;
}

.share-btn {
  line-height: 1.5;
  border: none;
  margin: 0;
}

.share-btn::after {
  border: none;
}

.action-btn-primary {
  background: #e94560;
  color: #fff;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}




/* 赛程卡片 */
.match-card {
  cursor: pointer;
}

.match-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.match-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 排行榜 */
.rank-card {
  cursor: pointer;
}

.rank-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #999;
  min-width: 48rpx;
  text-align: center;
}

.rank-top {
  color: #e94560;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 4rpx;
}

.total-points {
  font-size: 36rpx;
  font-weight: 700;
}

.points-positive {
  color: #4caf50;
}

.points-negative {
  color: #f44336;
}
