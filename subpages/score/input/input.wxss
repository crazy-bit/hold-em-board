/* pages/score/input/input.wxss */
.info-card {
  padding: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #a0a0b0;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #eaeaea;
}

.bonus {
  color: #ff9800;
}

.preview-points {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 20rpx;
  gap: 8rpx;
}

.preview-label {
  font-size: 26rpx;
  color: #a0a0b0;
}

.preview-value {
  font-size: 36rpx;
  font-weight: 700;
}

.positive {
  color: #4caf50;
}

.negative {
  color: #f44336;
}

.sign-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #3a3a4a;
  margin-right: 4rpx;
}

.sign-toggle-text {
  font-size: 26rpx;
  color: #c0c0d0;
  font-weight: 600;
  letter-spacing: -1rpx;
}
