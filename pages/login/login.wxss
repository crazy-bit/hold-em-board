/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.login-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 48rpx;
  width: 100%;
  backdrop-filter: blur(10px);
}

.login-tip {
  display: block;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 128rpx;
  height: 128rpx;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 4rpx dashed rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-plus {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

.avatar-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

.nickname-row {
  margin-bottom: 40rpx;
}

.nickname-input {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  color: #fff;
  text-align: center;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.btn-login {
  background: #e94560;
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  padding: 28rpx 0;
  text-align: center;
  border: none;
  width: 100%;
}

.btn-login::after {
  border: none;
}
