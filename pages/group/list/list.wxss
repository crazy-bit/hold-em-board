/* pages/group/list/list.wxss */
.header {
  margin-bottom: 32rpx;
}

.icon-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f0f0f0;
  font-size: 26rpx;
  color: #555;
}

.icon-btn-primary {
  background: #e94560;
  color: #fff;
}

.group-card {
  cursor: pointer;
}

.group-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.tag-admin {
  background: #fff3e0;
  color: #ff9800;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

.invite-code-input {
  text-transform: uppercase;
  text-align: center;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
}

.join-modal-body {
  padding: 24rpx 32rpx;
  overflow: hidden;
}

.join-modal-btns {
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.join-modal-btns van-button {
  flex: 1;
  min-width: 0;
}


