<!-- pages/group/create/create.wxml -->
<view class="container">
  <text class="page-title">创建赛事</text>

  <view class="card">
    <t-input
      label="赛事名称"
      placeholder="例如：周五德州局"
      value="{{groupName}}"
      bind:change="onNameInput"
      maxlength="20"
      clearable
    />
    <text class="char-count">{{groupName.length}}/20</text>
  </view>

  <view style="margin-top:48rpx;">
    <t-button
      theme="danger"
      block
      shape="round"
      bindtap="createGroup"
      disabled="{{creating || !groupName}}"
      loading="{{creating}}"
    >
      创建赛事
    </t-button>
  </view>
</view>

<t-toast id="t-toast" />
