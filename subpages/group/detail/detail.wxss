/* pages/group/detail/detail.wxss */
.group-header {
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #eaeaea;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-code {
  font-size: 24rpx;
  color: #a0a0b0;
  display: block;
}

.action-btns {
  flex-shrink: 0;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #16213e;
  font-size: 26rpx;
  color: #a0a0b0;
  white-space: nowrap;
}

.share-btn-wrap {
  position: relative;
  overflow: hidden;
}

.action-btn-primary {
  background: #e94560;
  color: #fff;
}

/* 二维码分享弹窗 */
.qrcode-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-panel {
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #eaeaea;
  margin-bottom: 32rpx;
  text-align: center;
}

.qrcode-img-wrap {
  width: 320rpx;
  height: 320rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.qrcode-img {
  width: 300rpx;
  height: 300rpx;
  border-radius: 12rpx;
}

.qrcode-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.qrcode-loading-text {
  font-size: 26rpx;
  color: #999;
}

.qrcode-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 28rpx;
}

.qrcode-invite-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.qrcode-invite-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.qrcode-invite-code {
  font-size: 28rpx;
  font-weight: 700;
  color: #e94560;
  flex: 1;
  letter-spacing: 4rpx;
}

.qrcode-copy-btn {
  font-size: 24rpx;
  color: #4caf50;
  padding: 4rpx 16rpx;
  border: 1rpx solid #4caf50;
  border-radius: 8rpx;
}

.qrcode-close {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 16rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 48rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #a0a0b0;
}

/* 赛程卡片 */
.match-card {
  cursor: pointer;
}

.match-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #eaeaea;
  display: block;
  margin-bottom: 8rpx;
}

.match-date {
  font-size: 24rpx;
  color: #a0a0b0;
  display: block;
}

.arrow {
  font-size: 32rpx;
  color: #666680;
  line-height: 48rpx;
}

/* 排行榜 */
.rank-card {
  cursor: pointer;
}

.rank-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
}

.rank-points-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  height: 48rpx;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #16213e;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #a0a0b0;
}

.rank-gold {
  background: #FFD700;
  color: #1a1a2e;
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.4);
}

.rank-silver {
  background: #C0C0C0;
  color: #1a1a2e;
}

.rank-bronze {
  background: #CD7F32;
  color: #fff;
}

.rank-top {
  color: #e94560;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #eaeaea;
  display: block;
  margin-bottom: 4rpx;
}

.rank-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.rank-avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #16213e;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.total-points {
  font-size: 36rpx;
  font-weight: 700;
  text-align: right;
  min-width: 80rpx;
  line-height: 1;
}

.points-positive {
  color: #4caf50;
}

.points-negative {
  color: #f44336;
}
