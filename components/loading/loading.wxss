/* components/loading/loading.wxss */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 26rpx;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #eee;
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
