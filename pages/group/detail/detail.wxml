<!-- pages/group/detail/detail.wxml -->
<view class="container">
  <!-- 组信息头部 -->
  <view class="group-header card">
    <view class="flex-between">
      <view>
        <text class="group-name">{{group.name}}</text>
        <text class="invite-code">邀请码：{{group.inviteCode}}</text>
      </view>
      <view class="flex-row" style="gap:16rpx;">
        <view class="action-btn" bindtap="shareGroup" wx:if="{{isAdmin}}">分享</view>
        <view class="action-btn action-btn-primary" bindtap="goRules" wx:if="{{isAdmin}}">规则</view>
      </view>
    </view>
    <view class="flex-row" style="margin-top:20rpx;gap:32rpx;">
      <text class="meta-text">{{members.length}} 位成员</text>
      <text class="meta-text">{{matches.length}} 期赛程</text>
    </view>
  </view>

  <!-- 管理员操作区 -->
  <view wx:if="{{isAdmin}}">
    <button class="btn-primary" bindtap="createMatch" style="margin-bottom:24rpx;">
      + 创建新赛程
    </button>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'matches' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="matches"
    >赛程记录</view>
    <view
      class="tab-item {{activeTab === 'leaderboard' ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="leaderboard"
    >总积分榜</view>
  </view>

  <!-- 赛程列表 -->
  <view wx:if="{{activeTab === 'matches'}}">
    <view class="empty-state" wx:if="{{matches.length === 0}}">
      <text style="font-size:60rpx;">🎲</text>
      <text style="margin-top:16rpx;">还没有赛程</text>
    </view>
    <view
      class="match-card card"
      wx:for="{{matches}}"
      wx:key="_id"
      bindtap="goMatchDetail"
      data-id="{{item._id}}"
    >
      <view class="flex-between">
        <view>
          <text class="match-title">{{item.title || '第' + item.index + '期'}}</text>
          <text class="match-date">{{item.createdAtStr}}</text>
        </view>
        <view class="flex-row" style="gap:12rpx;">
          <view class="tag {{item.status === 'active' ? 'tag-active' : item.status === 'finished' ? 'tag-finished' : 'tag-cancelled'}}">
            {{item.status === 'active' ? '进行中' : item.status === 'finished' ? '已结束' : '已作废'}}
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 总积分榜 -->
  <view wx:if="{{activeTab === 'leaderboard'}}">
    <view class="empty-state" wx:if="{{leaderboard.length === 0}}">
      <text style="font-size:60rpx;">🏆</text>
      <text style="margin-top:16rpx;">暂无积分数据</text>
    </view>
    <view
      class="rank-card card"
      wx:for="{{leaderboard}}"
      wx:key="userId"
      bindtap="goMemberDetail"
      data-userid="{{item.userId}}"
    >
      <view class="flex-between">
        <view class="flex-row" style="gap:24rpx;">
          <text class="rank-num {{index < 3 ? 'rank-top' : ''}}">
            {{index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : index + 1}}
          </text>
          <view>
            <text class="member-name">{{item.nickName}}</text>
            <text class="meta-text">参与 {{item.matchCount}} 期</text>
          </view>
        </view>
        <view class="flex-row" style="gap:12rpx;">
          <text class="total-points {{item.totalPoints >= 0 ? 'points-positive' : 'points-negative'}}">
            {{item.totalPoints >= 0 ? '+' : ''}}{{item.totalPoints}}
          </text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
