<!-- pages/group/detail/detail.wxml -->
<view class="container">
  <!-- 组信息头部 -->
  <view class="group-header card">
    <view class="flex-between" style="align-items:flex-start;">
      <view style="flex:1;min-width:0;margin-right:16rpx;">
        <text class="group-name">{{group.name}}</text>
        <text class="invite-code" bindtap="copyInviteCode">邀请码：{{group.inviteCode}}</text>
      </view>
      <view class="flex-row action-btns" wx:if="{{isAdmin}}">
        <view class="action-btn" bindtap="showShareQRCode">分享</view>
        <view class="action-btn action-btn-primary" bindtap="goRules">规则</view>
      </view>
    </view>
    <view class="flex-row" style="margin-top:20rpx;gap:32rpx;">
      <text class="meta-text">{{members.length}} 位成员</text>
      <text class="meta-text">{{matches.length}} 期赛程</text>
    </view>
  </view>

  <!-- 管理员操作区 -->
  <view wx:if="{{isAdmin}}">
    <t-button theme="danger" block shape="round" bindtap="createMatch" style="margin-bottom:24rpx;">
      + 创建新赛程
    </t-button>
  </view>

  <!-- Tab 切换 -->
  <t-tabs value="{{activeTabIndex}}" bind:change="onTabChange" style="--td-tab-item-active-color: #e94560; --td-tab-track-color: #e94560;">
    <t-tab-panel label="赛程记录" value="0">
      <!-- 赛程列表 -->
      <t-empty icon="search" description="还没有赛程" wx:if="{{matches.length === 0}}" />
      <view wx:else style="padding-top: 16rpx;">
        <view
          class="match-card card"
          wx:for="{{matches}}"
          wx:key="_id"
          bindtap="goMatchDetail"
          data-id="{{item._id}}"
        >
          <view class="flex-between">
            <view>
              <text class="match-title">{{item.title || '第' + item.index + '期'}}</text>
              <text class="match-date">{{item.createdAtStr}}</text>
            </view>
            <view class="flex-row" style="gap:12rpx;">
              <t-tag theme="success" shape="round" variant="light" wx:if="{{item.status === 'active'}}">进行中</t-tag>
              <t-tag theme="primary" shape="round" variant="light" wx:elif="{{item.status === 'finished'}}">已结束</t-tag>
              <t-tag theme="default" shape="round" variant="light" wx:else>已作废</t-tag>
              <text class="arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="总积分榜" value="1">
      <!-- 总积分榜 -->
      <t-empty description="暂无积分数据" wx:if="{{leaderboard.length === 0}}" />
      <view wx:else style="padding-top: 16rpx;">
        <view
          class="rank-card card"
          wx:for="{{leaderboard}}"
          wx:key="userId"
          bindtap="goMemberDetail"
          data-userid="{{item.userId}}"
        >
          <view class="rank-row">
            <view class="flex-row" style="gap:16rpx;flex:1;min-width:0;">
              <view class="rank-badge {{index === 0 ? 'rank-gold' : index === 1 ? 'rank-silver' : index === 2 ? 'rank-bronze' : ''}}">
                <text>{{index + 1}}</text>
              </view>
              <image class="rank-avatar" src="{{item.avatarUrl}}" wx:if="{{item.avatarUrl}}" />
              <view class="rank-avatar-placeholder" wx:else>
                <text style="font-size:22rpx;color:#666680;">{{item.nickName[0] || '?'}}</text>
              </view>
              <view style="flex:1;min-width:0;">
                <text class="member-name">{{item.nickName}}</text>
                <text class="meta-text">参与 {{item.matchCount}} 期</text>
              </view>
            </view>
            <text class="total-points {{item.totalPoints >= 0 ? 'points-positive' : 'points-negative'}}">
                {{item.totalPoints >= 0 ? '+' : ''}}{{item.totalPoints}}
            </text>
          </view>
        </view>
      </view>
    </t-tab-panel>

    <t-tab-panel label="积分趋势" value="2">
      <!-- 积分趋势曲线图 -->
      <view style="padding-top: 16rpx;">
        <trend-chart series="{{trendSeries}}" labels="{{trendLabels}}" />
      </view>
    </t-tab-panel>
  </t-tabs>
</view>

<t-toast id="t-toast" />

<!-- 二维码分享弹窗 -->
<view class="qrcode-mask" wx:if="{{showQRCode}}" bindtap="hideShareQRCode">
  <view class="qrcode-panel" catchtap="">
    <text class="qrcode-title">扫码加入「{{group.name}}」</text>
    <view class="qrcode-img-wrap">
      <image
        wx:if="{{qrCodeBase64}}"
        class="qrcode-img"
        src="{{qrCodeBase64}}"
        mode="aspectFit"
        show-menu-by-longpress
      />
      <view wx:elif="{{qrCodeLoading}}" class="qrcode-loading">
        <text class="qrcode-loading-text">生成中...</text>
      </view>
      <view wx:else class="qrcode-loading">
        <text class="qrcode-loading-text">生成失败，请重试</text>
      </view>
    </view>
    <text class="qrcode-hint">长按图片保存或转发给好友</text>
    <view class="qrcode-invite-row">
      <text class="qrcode-invite-label">邀请码：</text>
      <text class="qrcode-invite-code">{{group.inviteCode}}</text>
      <text class="qrcode-copy-btn" bindtap="copyInviteCode">复制</text>
    </view>
    <view class="qrcode-close" bindtap="hideShareQRCode">关闭</view>
  </view>
</view>
