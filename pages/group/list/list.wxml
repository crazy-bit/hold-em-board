<!-- pages/group/list/list.wxml -->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header flex-between">
    <text class="page-title" style="margin-bottom:0;">我的组团</text>
    <view class="flex-row" style="gap:24rpx;">
      <view class="icon-btn" bindtap="goJoinGroup">
        <text>加入</text>
      </view>
      <view class="icon-btn icon-btn-primary" bindtap="goCreateGroup">
        <text>+ 创建</text>
      </view>
    </view>
  </view>

  <!-- 加载中 - 骨架屏 -->
  <t-skeleton theme="paragraph" loading="{{loading}}" wx:if="{{loading}}" />

  <!-- 游客态：未登录时展示 -->
  <view wx:elif="{{!isLoggedIn}}" class="guest-state" style="padding:80rpx 40rpx;text-align:center;">
    <view style="font-size:80rpx;margin-bottom:24rpx;">🃏</view>
    <view style="font-size:32rpx;color:#e94560;font-weight:bold;margin-bottom:16rpx;">登录后查看组团</view>
    <view style="font-size:26rpx;color:#888;margin-bottom:48rpx;">登录后可创建或加入组团，记录每一局的胜负</view>
    <t-button theme="danger" shape="round" block bindtap="goLogin">登录开始使用</t-button>
  </view>

  <!-- 空状态 -->
  <t-empty description="还没有加入任何组团" wx:elif="{{groups.length === 0}}">
    <t-button slot="operation" theme="danger" shape="round" size="small" bindtap="goJoinGroup" style="margin-top: 20rpx;">
      加入组团
    </t-button>
  </t-empty>

  <!-- 组团列表 -->
  <view wx:else>
    <view
      class="group-card card"
      wx:for="{{groups}}"
      wx:key="_id"
      bindtap="goGroupDetail"
      data-id="{{item._id}}"
    >
      <view class="flex-between">
        <view>
          <text class="group-name">{{item.name}}</text>
          <view class="flex-row" style="margin-top:12rpx;gap:16rpx;">
            <text class="meta-text">{{item.memberCount || 0}} 人</text>
            <text class="meta-text">·</text>
<text class="meta-text">{{item.matchCount || 0}} 期对局</text>
          </view>
        </view>
        <view class="flex-row" style="gap:12rpx;">
          <t-tag theme="warning" shape="round" variant="light" wx:if="{{item.isAdmin}}">管理员</t-tag>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加入组弹窗 -->
<t-dialog
  title="加入组团"
  visible="{{showJoinModal}}"
  confirm-btn="{{null}}"
  cancel-btn="{{null}}"
  close-on-overlay-click
  bind:close="closeJoinModal"
>
  <view slot="content" class="join-modal-body">
    <input
      class="input-field invite-code-input"
      placeholder="输入6位邀请码"
      value="{{inviteCode}}"
      bindinput="onInviteCodeInput"
      maxlength="6"
    />
    <view class="join-modal-btns">
      <t-button variant="outline" shape="round" style="width:100%;flex:1;min-width:0;" bindtap="closeJoinModal">取消</t-button>
      <t-button theme="danger" shape="round" style="width:100%;flex:1;min-width:0;" bindtap="confirmJoin" loading="{{joining}}" disabled="{{joining}}">确认加入</t-button>
    </view>
  </view>
</t-dialog>

<t-toast id="t-toast" />
