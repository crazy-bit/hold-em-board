.chart-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx 16rpx;
}

.chart-canvas {
  display: block;
}

.legend-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 32rpx;
  padding: 16rpx 8rpx 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.chart-empty {
  padding: 80rpx 0;
  text-align: center;
}

.chart-empty-text {
  font-size: 26rpx;
  color: #bbb;
}
