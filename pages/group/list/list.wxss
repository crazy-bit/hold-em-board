/* pages/group/list/list.wxss */
.header {
  margin-bottom: 32rpx;
}

.icon-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f0f0f0;
  font-size: 26rpx;
  color: #555;
}

.icon-btn-primary {
  background: #e94560;
  color: #fff;
}

.group-card {
  cursor: pointer;
}

.group-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.tag-admin {
  background: #fff3e0;
  color: #ff9800;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 80%;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 40rpx;
}
