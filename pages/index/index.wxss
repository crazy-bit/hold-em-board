/* pages/index/index.wxss */
.summary-card {
  cursor: pointer;
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  margin-bottom: 32rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.stat-value-wrap {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-medal {
  font-size: 56rpx;
  line-height: 1;
}

.rank-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.rank-none {
  color: #ccc;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.points-positive {
  color: #4caf50;
}

.points-negative {
  color: #f44336;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.go-detail {
  font-size: 26rpx;
  color: #e94560;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.empty-actions {
  width: 100%;
  max-width: 480rpx;
}
