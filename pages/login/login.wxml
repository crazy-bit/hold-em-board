<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="logo-wrap">
    <view class="logo-icon">🃏</view>
    <text class="app-name">德州记分板</text>
    <text class="app-desc">轻松记录每一局的胜负</text>
  </view>

  <view class="login-card">
    <text class="login-tip">登录后即可创建或加入记分组</text>
    <button
      class="btn-login"
      bindtap="onLoginTap"
      wx:if="{{!loading}}"
    >
      微信一键登录
    </button>
    <view class="loading-wrap" wx:else>
      <text>登录中...</text>
    </view>
  </view>
</view>
