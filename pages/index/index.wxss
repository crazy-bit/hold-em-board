/* pages/index/index.wxss */
.home-banner {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.page-title-home {
  font-size: 40rpx;
  font-weight: 700;
  color: #eaeaea;
  margin-bottom: 32rpx;
  margin-top: 16rpx;
}

.summary-card {
  cursor: pointer;
  margin-bottom: 24rpx;
}

.group-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #eaeaea;
  display: block;
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  margin-bottom: 32rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #a0a0b0;
  margin-bottom: 16rpx;
}

.stat-circle {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #eaeaea;
}

.rank-gold {
  width: 56rpx;
  border-radius: 50%;
  background: #FFD700;
  color: #1a1a2e;
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.4);
}

.rank-silver {
  width: 56rpx;
  border-radius: 50%;
  background: #C0C0C0;
  color: #1a1a2e;
}

.rank-bronze {
  width: 56rpx;
  border-radius: 50%;
  background: #CD7F32;
  color: #fff;
}

.points-positive {
  color: #4caf50;
}

.points-negative {
  color: #f44336;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.meta-text {
  font-size: 24rpx;
  color: #a0a0b0;
}

.go-detail {
  font-size: 26rpx;
  color: #e94560;
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #eaeaea;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #a0a0b0;
  margin-bottom: 60rpx;
}

.empty-actions {
  width: 100%;
  max-width: 480rpx;
}

/* demo 体验模式 */
.demo-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(233, 69, 96, 0.12);
  border: 1rpx solid rgba(233, 69, 96, 0.3);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.demo-banner-text {
  font-size: 24rpx;
  color: #e94560;
}

.demo-login-tip {
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.demo-tip-text {
  font-size: 26rpx;
  color: #a0a0b0;
  line-height: 1.6;
}
