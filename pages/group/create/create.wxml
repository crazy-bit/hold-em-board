<!-- pages/group/create/create.wxml -->
<view class="container">
  <text class="page-title">创建赛事</text>

  <view class="card">
    <van-field
      label="赛事名称"
      placeholder="例如：周五德州局"
      value="{{groupName}}"
      bind:change="onNameInput"
      maxlength="20"
      clearable
    />
    <text class="char-count">{{groupName.length}}/20</text>
  </view>

  <view style="margin-top:48rpx;">
    <van-button
      type="danger"
      block
      round
      bindtap="createGroup"
      disabled="{{creating || !groupName}}"
      loading="{{creating}}"
      loading-text="创建中..."
    >
      创建赛事
    </van-button>
  </view>
</view>

<van-toast id="van-toast" />
