<!-- pages/group/list/list.wxml -->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header flex-between">
    <text class="page-title" style="margin-bottom:0;">我的记分组</text>
    <view class="flex-row" style="gap:24rpx;">
      <view class="icon-btn" bindtap="goJoinGroup">
        <text>加入</text>
      </view>
      <view class="icon-btn icon-btn-primary" bindtap="goCreateGroup">
        <text>+ 创建</text>
      </view>
    </view>
  </view>

  <!-- 加载中 - 骨架屏 -->
  <van-skeleton title row="3" loading="{{loading}}" wx:if="{{loading}}" />

  <!-- 空状态 -->
  <van-empty description="还没有加入任何记分组" wx:elif="{{groups.length === 0}}">
    <van-button slot="bottom" round type="danger" size="small" bindtap="goJoinGroup" custom-style="margin-top: 20rpx;">
      加入记分组
    </van-button>
  </van-empty>

  <!-- 记分组列表 -->
  <view wx:else>
    <view
      class="group-card card"
      wx:for="{{groups}}"
      wx:key="_id"
      bindtap="goGroupDetail"
      data-id="{{item._id}}"
    >
      <view class="flex-between">
        <view>
          <text class="group-name">{{item.name}}</text>
          <view class="flex-row" style="margin-top:12rpx;gap:16rpx;">
            <text class="meta-text">{{item.memberCount || 0}} 人</text>
            <text class="meta-text">·</text>
            <text class="meta-text">{{item.matchCount || 0}} 期赛程</text>
          </view>
        </view>
        <view class="flex-row" style="gap:12rpx;">
          <van-tag type="warning" round wx:if="{{item.isAdmin}}">管理员</van-tag>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加入组弹窗 -->
<van-dialog
  use-slot
  title="加入记分组"
  show="{{showJoinModal}}"
  show-confirm-button="{{false}}"
  show-cancel-button="{{false}}"
  close-on-click-overlay
  bind:close="closeJoinModal"
>
  <view class="join-modal-body">
    <input
      class="input-field invite-code-input"
      placeholder="输入6位邀请码"
      value="{{inviteCode}}"
      bindinput="onInviteCodeInput"
      maxlength="6"
    />
    <view class="join-modal-btns">
      <van-button plain round custom-style="width:100%;" bindtap="closeJoinModal">取消</van-button>
      <van-button type="danger" round custom-style="width:100%;" bindtap="confirmJoin" loading="{{joining}}" disabled="{{joining}}">确认加入</van-button>
    </view>
  </view>
</van-dialog>

<van-toast id="van-toast" />
