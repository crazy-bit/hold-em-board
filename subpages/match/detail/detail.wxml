<!-- pages/match/detail/detail.wxml -->
<view class="container">
  <!-- 赛程头部信息 -->
  <view class="match-header card">
    <view class="flex-between">
      <view>
        <text class="match-title">{{match.title || '赛程详情'}}</text>
        <text class="match-date">{{match.createdAtStr}}</text>
      </view>
      <van-tag type="success" round wx:if="{{match.status === 'active'}}">进行中</van-tag>
      <van-tag type="primary" round wx:elif="{{match.status === 'finished'}}">已结束</van-tag>
      <van-tag color="#fafafa" text-color="#999" round wx:else>已作废</van-tag>
    </view>
  </view>

  <!-- 管理员操作区（仅进行中赛程） -->
  <view wx:if="{{isAdmin && match.status === 'active'}}" class="admin-actions">
    <van-button type="danger" block round bindtap="finishMatch">结束赛程</van-button>
    <van-button plain block round color="#ff4d4f" custom-style="margin-top:16rpx;" bindtap="cancelMatch">销毁赛程（作废）</van-button>
  </view>

  <!-- 分数列表 -->
  <view class="scores-section">
    <text class="section-title">成员分数</text>

    <!-- 表头 -->
    <view class="score-grid score-header">
      <text class="col-name">成员</text>
      <text class="col-header">初始筹码</text>
      <text class="col-header">额外加成</text>
      <text class="col-header">结算筹码</text>
      <text class="col-header col-last">本期积分</text>
    </view>

    <!-- 分数行 -->
    <view
      class="score-row card"
      wx:for="{{scores}}"
      wx:key="userId"
      bindtap="goInputScore"
      data-userid="{{item.userId}}"
      data-scoreid="{{item._id}}"
    >
      <view class="score-grid">
        <view class="col-name-wrap">
          <text class="member-name">{{item.nickName}}</text>
          <text class="self-tag" wx:if="{{item.isSelf}}">我</text>
        </view>
        <text class="col-val">{{item.initialChips}}</text>
        <text class="col-val bonus">+{{item.bonus || 0}}</text>
        <text class="col-val {{item.finalChips !== null ? '' : 'unfilled'}}">{{item.finalChips !== null ? item.finalChips : '待填写'}}</text>
        <text class="col-val col-last {{item.points >= 0 ? 'positive' : 'negative'}}" wx:if="{{item.points !== null}}">{{item.points >= 0 ? '+' : ''}}{{item.points}}</text>
        <text class="col-val col-last unfilled" wx:else>-</text>
      </view>
    </view>
  </view>

  <!-- 未填写提示 -->
  <view class="unfilled-tip" wx:if="{{unfilledCount > 0 && match.status === 'active'}}">
    <text>还有 {{unfilledCount}} 人未填写结算筹码</text>
  </view>
</view>

<!-- 结束赛程确认弹窗 -->
<van-dialog
  use-slot
  title="确认结束赛程？"
  show="{{showFinishModal}}"
  show-confirm-button="{{false}}"
  show-cancel-button="{{false}}"
  close-on-click-overlay
  bind:close="closeFinishModal"
>
  <view style="padding: 24rpx 32rpx;">
    <view wx:if="{{unfilledMembers.length > 0}}" class="unfilled-warning">
      <text>以下成员未填写结算筹码，将以 0 计算：</text>
      <text wx:for="{{unfilledMembers}}" wx:key="*this" class="unfilled-name">{{item}}</text>
    </view>
    <view style="margin-top:32rpx;display:flex;gap:16rpx;">
      <van-button plain round custom-style="flex:1;width:100%;min-width:0;" bindtap="closeFinishModal">取消</van-button>
      <van-button type="danger" round custom-style="flex:1;width:100%;min-width:0;" bindtap="confirmFinish" loading="{{finishing}}" disabled="{{finishing}}">确认结束</van-button>
    </view>
  </view>
</van-dialog>

<van-toast id="van-toast" />
