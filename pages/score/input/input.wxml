<!-- pages/score/input/input.wxml -->
<view class="container">
  <text class="page-title">填写结算筹码</text>

  <!-- 当前信息 -->
  <van-cell-group inset custom-class="info-card-group">
    <van-cell title="初始筹码" value="{{score.initialChips}}" />
    <van-cell title="额外加成" value="+{{score.bonus || 0}}" value-class="bonus-value" />
  </van-cell-group>

  <!-- 输入区 -->
  <view class="card" style="margin-top: 24rpx;">
    <van-field
      label="结算筹码"
      type="number"
      placeholder="输入你的结算筹码"
      value="{{finalChips}}"
      bind:change="onChipsInput"
      clearable
    />
    <view class="preview-points" wx:if="{{finalChips !== ''}}">
      <text class="preview-label">预计本期积分：</text>
      <text class="preview-value {{previewPoints >= 0 ? 'positive' : 'negative'}}">
        {{previewPoints >= 0 ? '+' : ''}}{{previewPoints}}
      </text>
    </view>
  </view>

  <van-button
    type="danger"
    block
    round
    custom-style="margin-top:48rpx;"
    bindtap="saveScore"
    disabled="{{saving || finalChips === ''}}"
    loading="{{saving}}"
    loading-text="保存中..."
  >
    保存
  </van-button>
</view>

<van-toast id="van-toast" />
