<!-- pages/match/detail/detail.wxml -->
<view class="container">
  <!-- 对局头部信息 -->
  <view class="match-header card">
    <view class="flex-between">
      <view>
        <text class="match-title">{{match.title || '对局详情'}}</text>
        <text class="match-date">{{match.createdAtStr}}</text>
      </view>
      <t-tag theme="success" shape="round" variant="light" wx:if="{{match.status === 'active'}}">进行中</t-tag>
      <t-tag theme="primary" shape="round" variant="light" wx:elif="{{match.status === 'finished'}}">已结束</t-tag>
      <t-tag theme="default" shape="round" variant="light" wx:else>已作废</t-tag>
    </view>
  </view>

  <!-- 管理员操作区（仅进行中对局） -->
  <view wx:if="{{isAdmin && match.status === 'active'}}" class="admin-actions">
    <t-button theme="danger" block shape="round" bindtap="finishMatch">结束对局</t-button>
    <t-button variant="outline" block shape="round" style="margin-top:16rpx;--td-button-default-border-color:#ff4d4f;--td-button-default-color:#ff4d4f;" bindtap="cancelMatch">销毁对局（作废）</t-button>
  </view>

  <!-- 分数列表 -->
  <view class="scores-section">
    <text class="section-title">成员分数</text>

    <!-- 表头 -->
    <view class="score-grid score-header">
      <text class="col-rank col-header">#</text>
      <text class="col-name">成员</text>
      <text class="col-header">初始积分</text>
      <text class="col-header">结算积分</text>
      <text class="col-header col-last">本期积分</text>
    </view>

    <!-- 分数行 -->
    <view
      class="score-row card"
      wx:for="{{scores}}"
      wx:key="userId"
      bindtap="goInputScore"
      data-userid="{{item.userId}}"
      data-scoreid="{{item._id}}"
    >
      <view class="score-grid">
        <!-- 排名 -->
        <view class="col-rank">
          <text wx:if="{{item.rank !== null}}" class="rank-badge {{item.rank === 1 ? 'rank-gold' : item.rank === 2 ? 'rank-silver' : item.rank === 3 ? 'rank-bronze' : 'rank-normal'}}">{{item.rank}}</text>
          <text wx:else class="rank-badge rank-empty">-</text>
        </view>
        <view class="col-name-wrap">
          <text class="member-name">{{item.nickName}}</text>
          <text class="self-tag" wx:if="{{item.isSelf}}">我</text>
        </view>
        <text class="col-val">{{item.initialChips}}</text>
        <text class="col-val {{item.finalChips !== null ? '' : 'unfilled'}}">{{item.finalChips !== null ? item.finalChips : '待填写'}}</text>
        <view class="col-val col-last" wx:if="{{item.roundPoints !== null && item.roundPoints !== undefined}}">
          <text class="{{item.roundPoints >= 0 ? 'positive' : 'negative'}}">{{item.roundPoints >= 0 ? '+' : ''}}{{item.roundPoints}}</text>
          <text class="bonus-tag" wx:if="{{item.bonus > 0}}">(bonus:{{item.bonus}})</text>
        </view>
        <text class="col-val col-last unfilled" wx:else>-</text>
      </view>
    </view>
  </view>

  <!-- 未填写提示 -->
  <view class="unfilled-tip" wx:if="{{unfilledCount > 0 && match.status === 'active'}}">
    <text>还有 {{unfilledCount}} 人未填写结算积分</text>
  </view>
</view>

<!-- 结束对局确认弹窗 -->
<t-dialog
  title="确认结束对局？"
  visible="{{showFinishModal}}"
  confirm-btn="{{null}}"
  cancel-btn="{{null}}"
  close-on-overlay-click
  bind:close="closeFinishModal"
>
  <view slot="content" style="padding: 24rpx 32rpx;">
    <view wx:if="{{unfilledMembers.length > 0}}" class="unfilled-warning">
      <text>以下成员未填写结算积分，将以 0 计算：</text>
      <text wx:for="{{unfilledMembers}}" wx:key="*this" class="unfilled-name">{{item}}</text>
    </view>
    <view style="margin-top:32rpx;display:flex;gap:16rpx;">
      <t-button variant="outline" shape="round" style="flex:1;width:100%;min-width:0;" bindtap="closeFinishModal">取消</t-button>
      <t-button theme="danger" shape="round" style="flex:1;width:100%;min-width:0;" bindtap="confirmFinish" loading="{{finishing}}" disabled="{{finishing}}">确认结束</t-button>
    </view>
  </view>
</t-dialog>

<t-toast id="t-toast" />
