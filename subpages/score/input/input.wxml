<!-- pages/score/input/input.wxml -->
<view class="container">
  <!-- 当前信息 -->
  <view class="card info-card">
    <view class="info-row">
      <text class="info-label">初始筹码</text>
      <text class="info-value">{{score.initialChips}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">额外加成</text>
      <text class="info-value bonus">+{{score.bonus || 0}}</text>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="card" style="margin-top: 24rpx;">
    <van-field
      label="结算筹码"
      type="number"
      placeholder="输入你的结算筹码"
      value="{{finalChips}}"
      bind:change="onChipsInput"
      clearable
    />
    <view class="preview-points" wx:if="{{finalChips !== ''}}">
      <text class="preview-label">预计本期积分：</text>
      <text class="preview-value {{previewPoints >= 0 ? 'positive' : 'negative'}}">{{previewPoints >= 0 ? '+' : ''}}{{previewPoints}}</text>
    </view>
  </view>

  <van-button
    type="danger"
    block
    round
    custom-style="margin-top:48rpx;"
    bindtap="saveScore"
    disabled="{{saving || finalChips === ''}}"
    loading="{{saving}}"
    loading-text="保存中..."
  >
    保存
  </van-button>
</view>

<van-toast id="van-toast" />
